# REQUIRES-PROPERTIES-FILE - # Do not remove this comment!
CREATE OR REPLACE DATASOURCE CUSTOM ds_wide_dummy
    FOLDER = '/ds'
    CLASSNAME='com.denodo.vdb.contrib.wrapper.xls.ExcelWrapper';

CREATE OR REPLACE WRAPPER CUSTOM ds_wide_dummy
    FOLDER = '/ds'
    DATASOURCENAME=ds_wide_dummy
    PARAMETERS (
      'Type of file' = 'Excel 2007 or later (*.xlsx)',
      'File location' = ROUTE LOCAL 'LocalConnection' '${databases.admin.folder.ds.views.custom.ds_wide_dummy.File location.ROUTE.LOCAL.PATH}',
