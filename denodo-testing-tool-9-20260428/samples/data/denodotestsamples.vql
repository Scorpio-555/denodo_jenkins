# ----------------------------------------------------------------------------
# DENODO TEST SAMPLES VDP DATABASE: INITIALIZATION SCRIPT
# ----------------------------------------------------------------------------
# Please read and modify the accompanying .properties file before importing!
# ----------------------------------------------------------------------------
#
# REQUIRES-PROPERTIES-FILE - # Do not remove this comment!
ENTER SINGLE USER MODE;
# ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++

# 
# #######################################
# USER CREATION
# #######################################
DROP USER IF EXISTS denodotestsamples;

CREATE USER denodotestsamples '${users.denodotestsamples.PASSWORD}'  ${users.denodotestsamples.PASSWORD.ENCRYPTED} ${users.denodotestsamples.PASSWORD.ALGORITHM}  'User for the Denodo Test Samples database';

# #######################################
# ROLE CREATION
# #######################################
# No roles

# 0 ====================================================================

# #######################################
# DATABASE
# #######################################
DROP DATABASE IF EXISTS denodotestsamples;

CREATE DATABASE denodotestsamples 'Virtual DataBase supporting the Denodo Testing Tool sample test sets';

CONNECT DATABASE denodotestsamples;

# #######################################
# LISTENERS JMS
# #######################################
# No listeners jms
# #######################################
# DATASOURCES
# #######################################
DROP DATASOURCE JDBC IF EXISTS acme_crm CASCADE;

CREATE DATASOURCE JDBC acme_crm
    DRIVERCLASSNAME = 'org.sqlite.JDBC'
    DATABASEURI = '${databases.denodotestsamples.datasources.jdbc.acme_crm.DATABASEURI}'
    USERNAME = '${databases.denodotestsamples.datasources.jdbc.acme_crm.USERNAME}'
    USERPASSWORD = ''
    CLASSPATH = ''
    DATABASENAME = 'SQLite'
    DATABASEVERSION = ''
    FETCHSIZE = 1000
    BATCHINSERTSIZE = 200
    VALIDATIONQUERY = ''
    INITIALSIZE = 4
    MAXIDLE = -1
    MINIDLE = 0
    MAXACTIVE = 20
    EXHAUSTEDACTION = 1
    TESTONBORROW = false
    TESTONRETURN = false
    TESTWHILEIDLE = false
    TIMEBETWEENEVICTION = -1
    NUMTESTPEREVICTION = 3
    MINEVICTABLETIME = 1800000
    POOLPREPAREDSTATEMENTS = false
    MAXSLEEPINGPS = 4
    INITIALCAPACITYPS = 8;

CHOWN admin DATASOURCE JDBC acme_crm LASTMODIFICATIONUSER admin;

DROP DATASOURCE JDBC IF EXISTS sakila CASCADE;

CREATE DATASOURCE JDBC sakila
    DRIVERCLASSNAME = 'org.sqlite.JDBC'
    DATABASEURI = '${databases.denodotestsamples.datasources.jdbc.sakila.DATABASEURI}'
    USERNAME = '${databases.denodotestsamples.datasources.jdbc.sakila.USERNAME}'
    USERPASSWORD = ''
    CLASSPATH = ''
    DATABASENAME = 'SQLite'
    DATABASEVERSION = ''
    FETCHSIZE = 1000
    BATCHINSERTSIZE = 200
    VALIDATIONQUERY = ''
    INITIALSIZE = 4
    MAXIDLE = -1
    MINIDLE = 0
    MAXACTIVE = 20
    EXHAUSTEDACTION = 1
    TESTONBORROW = false
    TESTONRETURN = false
    TESTWHILEIDLE = false
    TIMEBETWEENEVICTION = -1
    NUMTESTPEREVICTION = 3
    MINEVICTABLETIME = 1800000
    POOLPREPAREDSTATEMENTS = false
    MAXSLEEPINGPS = 4
    INITIALCAPACITYPS = 8;

CHOWN admin DATASOURCE JDBC sakila LASTMODIFICATIONUSER admin;

# #######################################
# DATABASE CONFIGURATION
# #######################################
ALTER DATABASE denodotestsamples
  CHARSET DEFAULT;

# #######################################
# WRAPPERS
# #######################################
DROP WRAPPER JDBC IF EXISTS acme_address CASCADE;

CREATE WRAPPER JDBC acme_address
    DATASOURCENAME=acme_crm
    SQLSENTENCE='select * from address'   
    OUTPUTSCHEMA (
        client_identifier = 'client_identifier' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='50')  NOT NULL NOT SORTABLE NOT UPDATEABLE,
        street = 'street' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='100')  NOT SORTABLE NOT UPDATEABLE,
        city = 'city' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='100')  NOT SORTABLE NOT UPDATEABLE,
        zip = 'zip' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='100')  NOT SORTABLE NOT UPDATEABLE,
        state = 'state' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='100')  NOT SORTABLE NOT UPDATEABLE,
        primary_phone = 'primary_phone' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='100')  NOT SORTABLE NOT UPDATEABLE,
        country = 'country' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='45')  NOT SORTABLE NOT UPDATEABLE
    );

CHOWN admin WRAPPER JDBC acme_address LASTMODIFICATIONUSER admin;

DROP WRAPPER JDBC IF EXISTS acme_client CASCADE;

CREATE WRAPPER JDBC acme_client
    DATASOURCENAME=acme_crm
    SQLSENTENCE='select * from client'   
    OUTPUTSCHEMA (
        client_id = 'client_id' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='50')  NOT NULL NOT SORTABLE NOT UPDATEABLE,
        name = 'name' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='100')  NOT SORTABLE NOT UPDATEABLE,
        surname = 'surname' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='100')  NOT SORTABLE NOT UPDATEABLE,
        client_type = 'client_type' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='2')  NOT SORTABLE NOT UPDATEABLE,
        company_code = 'company_code' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='50')  NOT SORTABLE NOT UPDATEABLE,
        ssn = 'ssn' :'java.lang.String' (sourcetypename='VARCHAR', sourcetypeid='12', sourcetypedecimals='0', sourcetypesize='45')  NOT SORTABLE NOT UPDATEABLE
    );

CHOWN admin WRAPPER JDBC acme_client LASTMODIFICATIONUSER admin;

