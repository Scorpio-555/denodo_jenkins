# ===========================================================================
%NAME Samples2, Suite 2: setup and teardown test
# ===========================================================================
%DESCRIPTION
# ??????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
Execute a query on the "sakila_country" view in VDP looking for a specific
tuple that we will have inserted first in the SETUP phase (%SETUP), and
then deleted during TEARDOWN (%TEARDOWN).
# ===========================================================================
%SETUP[query]
{ ds:sakila }
INSERT INTO country (country)
VALUES ('#{global.newcountry.name}')
# ---------------------------------------------------------------------------
%TEARDOWN[query]
{ ds:sakila }
DELETE FROM country
WHERE country = '#{global.newcountry.name}'
# ---------------------------------------------------------------------------
%EXECUTION[query]
{ ds:vdp }
SELECT DISTINCT country
FROM sakila_country
WHERE country like 'Ma%' OR country like 'Bar%'
# ---------------------------------------------------------------------------
%RESULTS[data]
{ ds:sakila, type:subset, ordered:no }
country
Mars
Barsoom
# ---------------------------------------------------------------------------
