# ===========================================================================
%NAME Samples2, Suite 1: addresses sakila subset
# ===========================================================================
%DESCRIPTION
# ??????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
Equivalent to the "addresses acme subset" test in this same suite, checks
that all the addresses contained in the "sakila" data source are actually a
subset of the addresses returned by VDP's "all_addresses" union view.
# ===========================================================================
%EXECUTION[query]
{ ds:vdp }
SELECT DISTINCT street, city, zip, country
FROM all_addresses
# ---------------------------------------------------------------------------
%RESULTS[query]
{
  ds:acme,
  ordered:no,
  type:subset
}
SELECT DISTINCT street, city, zip, country
FROM address
# ---------------------------------------------------------------------------
