# ===========================================================================
%NAME Samples1: Check multithreaded execution ${db_name}.${view_name}.

# ===========================================================================
%DESCRIPTION
# ??????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
This test checks if vDB views return at least 1 row.
This test was added to test multithreaded execution
# ===========================================================================
%CONTEXT
db_name = denodotestsamples
view_name[][]= [sakila_actor,sakila_address],[sakila_category,sakila_city],[sakila_country,sakila_customer,sakila_film]
# -
%EXECUTION[query]
{ ds:vdp }

SELECT 'OK' as result FROM ${db_name}.${view_name} LIMIT 1;

# ---------------------------------------------------------------------------
%RESULTS[data]
result
OK
# ---------------------------------------------------------------------------