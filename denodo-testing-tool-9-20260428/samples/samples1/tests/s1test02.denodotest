# ===========================================================================
%NAME Samples1: unordered results
# ===========================================================================
%DESCRIPTION
# ??????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
Same as the base test (one query, check results) but this time the expected
results are declared to be non-ordered. Note the context of the %RESULTS
directive, specifying "ordered:no".
# ===========================================================================
%EXECUTION[query]
{ ds:vdp }
SELECT first_name,last_name
FROM sakila_actor
WHERE first_name = 'PENELOPE'
# ---------------------------------------------------------------------------
%RESULTS[data]
{ ordered:no }
first_name,last_name
PENELOPE,MONROE
PENELOPE,PINKETT
PENELOPE,GUINESS
PENELOPE,CRONYN
# ---------------------------------------------------------------------------
