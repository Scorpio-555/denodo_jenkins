# ===========================================================================
%NAME Samples1: results as query to data source
# ===========================================================================
%DESCRIPTION
# ??????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????????
Query executed against VDP, with results checked against the results of
another query executed directly on the data source (see the "ds:sakila"
property of the %RESULTS context).
# ===========================================================================
%EXECUTION[query]
{ ds:vdp }
SELECT first_name,last_name
FROM sakila_actor
WHERE first_name = 'PENELOPE'
# ---------------------------------------------------------------------------
%RESULTS[query]
{
  ds:sakila,
  ordered:no
}
SELECT first_name,last_name
FROM actor
WHERE first_name = 'PENELOPE'
# ---------------------------------------------------------------------------
